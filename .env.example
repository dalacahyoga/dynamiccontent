# Supabase (opsional, tapi direkomendasikan).
# Saat di-set, login admin memakai Supabase Auth dan data pengunjung + pilihan
# konten dibagi ke SEMUA pengunjung/device. Saat kosong, aplikasi otomatis
# fallback ke localStorage (per-browser, login portfolio/portfolio).
#
# Salin file ini menjadi .env lalu isi dari Supabase dashboard
# (Project Settings -> API).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
